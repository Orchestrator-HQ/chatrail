    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skills/chatrail/scripts/chatrail.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
